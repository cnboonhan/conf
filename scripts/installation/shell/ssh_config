Host github.com
  HostName github.com
  User git
  IdentityFile ~/.decrypt/.ssh/id_rsa_github

Host gitlab.local.com
  HostName gitlab.local.com
  User git
  IdentityFile ~/.decrypt/.ssh/id_rsa_gitlab

# Travel Hotspot
Host hotspot
  User root
  HostName 192.168.1.1
  Port 22
  IdentityFile ~/.decrypt/.ssh/id_rsa

# Android Phone Proxy
Host proxy
  User root
  HostName linux.local
  Port 8022
  IdentityFile ~/.decrypt/.ssh/id_rsa
